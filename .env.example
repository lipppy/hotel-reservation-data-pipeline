# Copy this file to .env and replace the placeholder values with your Apaleo app credentials.
APALEO_CLIENT_ID=your_client_id_here
APALEO_CLIENT_SECRET=your_client_secret_here

# MySQL connection settings used by docker-compose.yml (db service) and app code.
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=hotel_reservations
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_HOST=db
MYSQL_PORT=3306